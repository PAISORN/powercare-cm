# Supabase PostgreSQL for production/pilot.
# Do not commit your real password or real project ref in `.env`.
#
# Supabase Dashboard > Project > Connect > ORMs > Prisma
# Recommended:
# - DATABASE_URL: Supavisor session pooler, usually port 5432
# - DIRECT_URL: direct connection or migration-safe connection string

DATABASE_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"

SESSION_SECRET="replace-with-a-long-random-production-secret"
FILE_STORAGE_ROOT="./storage"

# Supabase Storage for profile photos and signatures.
# Keep this key server-side only. Never expose it as NEXT_PUBLIC_*.
FILE_STORAGE_DRIVER="supabase"
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-secret-service-role-key"
SUPABASE_PROFILE_PHOTOS_BUCKET="powercare-profile-photos"
SUPABASE_SIGNATURES_BUCKET="powercare-signatures"
SUPABASE_ORGANIZATION_LOGOS_BUCKET="powercare-organization-logos"
PRODUCTION_SUPABASE_PROJECT_REF="[PRODUCTION-PROJECT-REF]"

# LINE server credentials. Never prefix these with NEXT_PUBLIC_ or commit real values.
LINE_CHANNEL_ACCESS_TOKEN="replace-with-line-messaging-api-channel-access-token"
LINE_CHANNEL_SECRET="replace-with-line-messaging-api-channel-secret"

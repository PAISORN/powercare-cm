generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  passwordHash   String
  fullName       String
  department     String?
  role           String
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  plantId        String?
  plant          Plant?         @relation(fields: [plantId], references: [id])
  categoryId     String?
  category       Category?      @relation(fields: [categoryId], references: [id])
  categories     UserCategory[]
  signature      Signature?
  profilePhoto   ProfilePhoto?
  active         Boolean        @default(true)
  lastSeenAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  claimedWorks                CmWork[]              @relation("Claimant")
  closedWorks                 CmWork[]              @relation("EngineerReviewer")
  auditEvents                 AuditEvent[]
  announcements               Announcement[]        @relation("AnnouncementAuthor")
  notifications               UserNotification[]    @relation("NotificationRecipient")
  siteAdminPermissions        SiteAdminPermission[] @relation("SiteAdminPermissionUser")
  grantedSiteAdminPermissions SiteAdminPermission[] @relation("SiteAdminPermissionGrantedBy")
  stockMovements              StockMovement[]
  sparePartReceives           SparePartReceive[]
  requestedStoreIssues        SparePartIssue[]      @relation("StoreIssueRequester")
  engineerStoreIssues         SparePartIssue[]      @relation("StoreIssueEngineer")
  officerStoreIssues          SparePartIssue[]      @relation("StoreIssueOfficer")

  @@index([lastSeenAt])
}

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plants                  Plant[]
  users                   User[]
  categories              Category[]
  works                   CmWork[]
  lineDestinations        LineDestination[]
  announcements           Announcement[]
  feedback                PublicFeedback[]
  profiles                OrganizationProfile[]
  auditEvents             AuditEvent[]
  lineGroupDiscoveries    LineGroupDiscovery[]
  lineDailyReportSettings LineDailyReportSetting[]
  storeCategories         StoreCategory[]
  stores                  Store[]
  sparePartCategories     SparePartCategory[]
  sparePartTypes          SparePartType[]
  spareParts              SparePart[]
  storeApplicableZones    StoreApplicableZone[]
  storeStocks             StoreStock[]
  stockMovements          StockMovement[]
  sparePartReceives       SparePartReceive[]
  sparePartIssues         SparePartIssue[]

  @@index([active])
}

model Plant {
  id                              String       @id @default(cuid())
  organizationId                  String
  organization                    Organization @relation(fields: [organizationId], references: [id])
  code                            String
  inventoryCode                   String?      @unique
  publicStoreIssueEnabled         Boolean      @default(false)
  publicStoreIssueContactRequired Boolean      @default(false)
  name                            String
  maxUsers                        Int?
  maxWorkRequests                 Int?
  active                          Boolean      @default(true)
  createdAt                       DateTime     @default(now())
  updatedAt                       DateTime     @updatedAt

  users                   User[]
  categories              Category[]
  zones                   Zone[]
  works                   CmWork[]
  feedback                PublicFeedback[]
  auditEvents             AuditEvent[]
  siteAdminPermissions    SiteAdminPermission[]
  lineDestinations        LineDestination[]
  lineDailyReportSettings LineDailyReportSetting[]
  profile                 PlantProfile?
  slaSetting              SlaSetting?
  systemSetting           SystemSetting?
  storeCategories         StoreCategory[]
  stores                  Store[]
  sparePartCategories     SparePartCategory[]
  sparePartTypes          SparePartType[]
  spareParts              SparePart[]
  storeApplicableZones    StoreApplicableZone[]
  storeStocks             StoreStock[]
  stockMovements          StockMovement[]
  sparePartReceives       SparePartReceive[]
  sparePartIssues         SparePartIssue[]
  sparePartSequence       SparePartSequence?
  storeIssueSequences     StoreIssueSequence[]

  @@unique([organizationId, code])
  @@unique([organizationId, name])
  @@index([organizationId, active])
}

model SiteAdminPermission {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("SiteAdminPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  plantId       String
  plant         Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  permissionKey String
  enabled       Boolean  @default(false)
  grantedById   String?
  grantedBy     User?    @relation("SiteAdminPermissionGrantedBy", fields: [grantedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, plantId, permissionKey])
  @@index([plantId, permissionKey, enabled])
  @@index([grantedById])
}

model Signature {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  fileName    String
  mimeType    String
  fileSize    Int
  storagePath String
  uploadedAt  DateTime @default(now())
}

model ProfilePhoto {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  fileName    String
  mimeType    String
  fileSize    Int
  storagePath String
  checksum    String
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id             String        @id @default(cuid())
  name           String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  plantId        String?
  plant          Plant?        @relation(fields: [plantId], references: [id])
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users            User[]
  userCategories   UserCategory[]
  works            CmWork[]
  lineDestinations LineDestination[]

  @@unique([plantId, name])
  @@index([active])
  @@index([organizationId, active])
  @@index([plantId, active])
}

model UserCategory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, categoryId])
  @@index([categoryId])
}

model Zone {
  id        String   @id @default(cuid())
  name      String
  plantId   String?
  plant     Plant?   @relation(fields: [plantId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works                CmWork[]
  storeApplicableZones StoreApplicableZone[]
  sparePartIssueItems  SparePartIssueItem[]

  @@unique([plantId, name])
  @@index([active])
  @@index([plantId, active])
}

model CmWork {
  id                  String        @id @default(cuid())
  number              String        @unique
  requesterName       String
  requesterDepartment String
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  plantId             String?
  plant               Plant?        @relation(fields: [plantId], references: [id])
  categoryId          String
  category            Category      @relation(fields: [categoryId], references: [id])
  zoneId              String
  zone                Zone          @relation(fields: [zoneId], references: [id])
  machineName         String
  problemTitle        String
  problemDetail       String
  urgency             String
  status              String        @default("NEW")
  claimantId          String?
  claimant            User?         @relation("Claimant", fields: [claimantId], references: [id])
  rootCause           String?
  correctiveAction    String?
  workNote            String?
  engineerNote        String?
  canceledReason      String?
  releaseReason       String?
  returnedReason      String?
  createdAt           DateTime      @default(now())
  claimedAt           DateTime?
  inProgressAt        DateTime?
  waitingToCloseAt    DateTime?
  closedAt            DateTime?
  canceledAt          DateTime?
  reviewerId          String?
  reviewer            User?         @relation("EngineerReviewer", fields: [reviewerId], references: [id])

  statusHistory   StatusHistory[]
  auditEvents     AuditEvent[]
  sparePartIssues SparePartIssue[]
}

model CmNumberSequence {
  yearMonth  String   @id
  lastNumber Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StatusHistory {
  id          String   @id @default(cuid())
  cmWorkId    String
  cmWork      CmWork   @relation(fields: [cmWorkId], references: [id])
  fromStatus  String?
  toStatus    String
  changedById String?
  changedAt   DateTime @default(now())
  note        String?
}

model AuditEvent {
  id             String        @id @default(cuid())
  cmWorkId       String?
  cmWork         CmWork?       @relation(fields: [cmWorkId], references: [id])
  actorId        String?
  actor          User?         @relation(fields: [actorId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  plantId        String?
  plant          Plant?        @relation(fields: [plantId], references: [id])
  entityType     String
  entityId       String
  action         String
  beforeJson     String?
  afterJson      String?
  reason         String?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([plantId, createdAt])
  @@index([action, createdAt])
}

model SlaSetting {
  id            String   @id @default(cuid())
  plantId       String?  @unique
  plant         Plant?   @relation(fields: [plantId], references: [id])
  claimDays     Int      @default(1)
  executionDays Int      @default(3)
  reviewDays    Int      @default(2)
  updatedAt     DateTime @updatedAt
}

model SystemSetting {
  id                            String   @id
  plantId                       String?  @unique
  plant                         Plant?   @relation(fields: [plantId], references: [id])
  engineerWorkAssignmentEnabled Boolean  @default(false)
  updatedAt                     DateTime @updatedAt
}

model Announcement {
  id               String        @id @default(cuid())
  title            String
  content          String
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  imageFileName    String?
  imageMimeType    String?
  imageFileSize    Int?
  imageStoragePath String?
  publishStart     DateTime
  publishEnd       DateTime
  pinned           Boolean       @default(false)
  active           Boolean       @default(true)
  authorId         String
  author           User          @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([active, publishStart, publishEnd])
  @@index([pinned, publishStart])
  @@index([authorId])
}

model UserNotification {
  id           String    @id @default(cuid())
  recipientId  String
  recipient    User      @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  eventType    String
  entityType   String
  entityId     String
  targetStatus String?
  title        String
  message      String
  href         String?
  createdAt    DateTime  @default(now())
  readAt       DateTime?

  @@index([recipientId, readAt, createdAt])
  @@index([recipientId, targetStatus, readAt])
  @@index([recipientId, entityType, entityId, readAt])
  @@index([entityType, entityId])
  @@index([eventType])
}

model LineDestination {
  id             String        @id @default(cuid())
  displayName    String
  targetId       String        @unique
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  plantId        String?
  plant          Plant?        @relation(fields: [plantId], references: [id])
  categoryId     String?
  category       Category?     @relation(fields: [categoryId], references: [id])
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  settings            LineEventSetting[]
  deliveries          LineDeliveryLog[]
  discovery           LineGroupDiscovery?
  dailyReportSettings LineDailyReportSetting[]

  @@index([organizationId, active])
  @@index([plantId, active])
  @@index([categoryId, active])
}

model LineEventSetting {
  id            String          @id @default(cuid())
  destinationId String
  destination   LineDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  eventType     String
  enabled       Boolean         @default(true)

  @@unique([destinationId, eventType])
}

model LineDeliveryLog {
  id            String          @id @default(cuid())
  eventId       String
  destinationId String
  destination   LineDestination @relation(fields: [destinationId], references: [id])
  eventType     String
  payloadJson   String
  status        String          @default("PENDING")
  attempts      Int             @default(0)
  errorSummary  String?
  sentAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([eventId, destinationId])
  @@index([destinationId])
  @@index([status, createdAt])
}

model LineGroupDiscovery {
  id                 String           @id @default(cuid())
  groupId            String           @unique
  organizationId     String?
  organization       Organization?    @relation(fields: [organizationId], references: [id])
  displayName        String?
  eventType          String?
  firstSeenAt        DateTime         @default(now())
  lastSeenAt         DateTime         @default(now())
  addedDestinationId String?          @unique
  addedDestination   LineDestination? @relation(fields: [addedDestinationId], references: [id], onDelete: SetNull)

  @@index([organizationId, lastSeenAt])
  @@index([lastSeenAt])
}

model LineDailyReportSetting {
  id             String           @id
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  plantId        String?
  plant          Plant?           @relation(fields: [plantId], references: [id])
  enabled        Boolean          @default(false)
  destinationId  String?
  destination    LineDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  sendTime       String           @default("08:00")
  dateMode       String           @default("YESTERDAY")
  templateJson   String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
  @@index([plantId])
  @@index([destinationId])
}

model OrganizationProfile {
  id              String        @id
  organizationId  String?       @unique
  organization    Organization? @relation(fields: [organizationId], references: [id])
  companyName     String
  logoFileName    String?
  logoMimeType    String?
  logoFileSize    Int?
  logoStoragePath String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PlantProfile {
  id              String   @id
  plantId         String   @unique
  plant           Plant    @relation(fields: [plantId], references: [id])
  companyName     String?
  address         String?
  contactName     String?
  contactPhone    String?
  notes           String?
  logoFileName    String?
  logoMimeType    String?
  logoFileSize    Int?
  logoStoragePath String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StoreCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  stores Store[]

  @@unique([plantId, name])
  @@index([organizationId, active])
  @@index([plantId, active])
}

model Store {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant          @relation(fields: [plantId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       StoreCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  code           String
  name           String
  location       String?
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  stocks            StoreStock[]
  movements         StockMovement[]
  receiveItems      SparePartReceiveItem[]
  issueItems        SparePartIssueItem[]
  defaultSpareParts SparePart[]

  @@unique([plantId, code])
  @@unique([plantId, name])
  @@index([organizationId, active])
  @@index([plantId, active])
  @@index([categoryId])
}

model SparePartCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  code           String?
  name           String
  description    String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  spareParts SparePart[]

  @@unique([plantId, name])
  @@unique([plantId, code])
  @@index([organizationId, active])
  @@index([plantId, active])
}

model SparePartType {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  code           String
  name           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  spareParts SparePart[]

  @@unique([plantId, code])
  @@unique([plantId, name])
  @@index([organizationId, active])
  @@index([plantId, active])
}

model SparePart {
  id              String             @id @default(cuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id])
  plantId         String
  plant           Plant              @relation(fields: [plantId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        SparePartCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  typeId          String?
  type            SparePartType?     @relation(fields: [typeId], references: [id], onDelete: SetNull)
  defaultStoreId  String?
  defaultStore    Store?             @relation(fields: [defaultStoreId], references: [id], onDelete: SetNull)
  code            String
  itemCode        String?
  name            String
  description     String?
  unit            String
  latestUnitPrice Decimal?
  minStock        Decimal            @default(0)
  maxStock        Decimal?
  reorderPoint    Decimal            @default(0)
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  stocks       StoreStock[]
  movements    StockMovement[]
  receiveItems SparePartReceiveItem[]
  issueItems   SparePartIssueItem[]

  @@unique([plantId, code])
  @@unique([organizationId, itemCode])
  @@index([organizationId, active])
  @@index([plantId, active])
  @@index([plantId, itemCode])
  @@index([categoryId, active])
  @@index([typeId, active])
  @@index([defaultStoreId, active])
}

model StoreApplicableZone {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  zoneId         String
  zone           Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  code           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([plantId, zoneId])
  @@unique([plantId, code])
  @@index([organizationId, active])
  @@index([plantId, active])
  @@index([zoneId])
}

model SparePartSequence {
  plantId    String   @id
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StoreIssueSequence {
  id         String   @id @default(cuid())
  plantId    String
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([plantId, year, month])
  @@index([plantId])
}

model StoreStock {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sparePartId    String
  sparePart      SparePart    @relation(fields: [sparePartId], references: [id], onDelete: Cascade)
  quantity       Decimal      @default(0)
  updatedAt      DateTime     @updatedAt

  @@unique([storeId, sparePartId])
  @@index([organizationId])
  @@index([plantId])
  @@index([sparePartId])
}

model StockMovement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id])
  sparePartId    String
  sparePart      SparePart    @relation(fields: [sparePartId], references: [id])
  actorId        String?
  actor          User?        @relation(fields: [actorId], references: [id])
  movementType   String
  refType        String?
  refId          String?
  quantityChange Decimal
  balanceAfter   Decimal?
  unitPrice      Decimal?
  note           String?
  occurredAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@index([organizationId, occurredAt])
  @@index([plantId, occurredAt])
  @@index([storeId, occurredAt])
  @@index([sparePartId, occurredAt])
  @@index([movementType, occurredAt])
  @@index([refType, refId])
}

model SparePartReceive {
  id             String       @id @default(cuid())
  number         String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  receivedById   String?
  receivedBy     User?        @relation(fields: [receivedById], references: [id])
  supplierName   String?
  referenceNo    String?
  note           String?
  status         String       @default("RECEIVED")
  receivedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items SparePartReceiveItem[]

  @@index([organizationId, receivedAt])
  @@index([plantId, receivedAt])
  @@index([receivedById])
}

model SparePartReceiveItem {
  id          String           @id @default(cuid())
  receiveId   String
  receive     SparePartReceive @relation(fields: [receiveId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store            @relation(fields: [storeId], references: [id])
  sparePartId String
  sparePart   SparePart        @relation(fields: [sparePartId], references: [id])
  quantity    Decimal
  unitPrice   Decimal?
  note        String?

  @@index([storeId])
  @@index([sparePartId])
}

model SparePartIssue {
  id                  String       @id @default(cuid())
  number              String       @unique
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  plantId             String
  plant               Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  cmWorkId            String?
  cmWork              CmWork?      @relation(fields: [cmWorkId], references: [id], onDelete: SetNull)
  issueType           String
  status              String       @default("WAITING_ENGINEER_APPROVAL")
  requesterName       String
  requesterDepartment String?
  requesterContact    String?
  requesterUserId     String?
  requesterUser       User?        @relation("StoreIssueRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  engineerId          String?
  engineer            User?        @relation("StoreIssueEngineer", fields: [engineerId], references: [id], onDelete: SetNull)
  storeOfficerId      String?
  storeOfficer        User?        @relation("StoreIssueOfficer", fields: [storeOfficerId], references: [id], onDelete: SetNull)
  note                String?
  rejectReason        String?
  requestedAt         DateTime     @default(now())
  engineerApprovedAt  DateTime?
  issuedAt            DateTime?
  rejectedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  items SparePartIssueItem[]

  @@index([organizationId, requestedAt])
  @@index([plantId, requestedAt])
  @@index([cmWorkId])
  @@index([status, requestedAt])
  @@index([requesterUserId])
  @@index([engineerId])
  @@index([storeOfficerId])
}

model SparePartIssueItem {
  id           String         @id @default(cuid())
  lineNumber   String?
  issueId      String
  issue        SparePartIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  storeId      String?
  store        Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sparePartId  String
  sparePart    SparePart      @relation(fields: [sparePartId], references: [id])
  zoneId       String?
  zone         Zone?          @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  zoneCode     String?
  requestedQty Decimal
  approvedQty  Decimal?
  issuedQty    Decimal?
  unitPrice    Decimal?
  status       String         @default("REQUESTED")
  note         String?

  @@index([storeId])
  @@index([sparePartId])
  @@index([zoneId])
  @@index([status])
}

model PublicFeedback {
  id             String        @id @default(cuid())
  name           String
  department     String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  plantId        String?
  plant          Plant?        @relation(fields: [plantId], references: [id])
  message        String
  sourcePath     String?
  createdAt      DateTime      @default(now())

  @@index([createdAt])
}
